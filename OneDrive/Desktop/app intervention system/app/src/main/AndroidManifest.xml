<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to query app usage statistics from UsageStatsManager -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Required for WorkManager to schedule periodic usage tracking -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Foreground service permission for focus timer (optional) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Post notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Fallback overlay permission for the app lock screen -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".NeuroFocusApp"
        android:allowBackup="true"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="NeuroFocus"
        android:supportsRtl="true"
        android:theme="@style/Theme.NeuroFocus"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.NeuroFocus">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- App Lock overlay activity (XP-gated unlock, shown when a blocked app is opened) -->
        <activity
            android:name=".presentation.applock.AppLockedActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.NeuroFocus"
            android:launchMode="singleTop" />

        <!-- Block activity (daily timer limit reached, routes back to home) -->
        <activity
            android:name=".presentation.block.BlockActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.NeuroFocus"
            android:launchMode="singleTop" />

        <!-- XP-gated intercept activity (Pay to Open, session bypass) -->
        <activity
            android:name=".presentation.intercept.InterceptActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.NeuroFocus"
            android:launchMode="singleTop" />

        <!-- AccessibilityService for intercepting blocked app launches -->
        <service
            android:name=".service.AppInterceptorService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- WorkManager initializer for Hilt integration -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
